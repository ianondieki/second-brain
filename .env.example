# ==============================================================================
#  Copy to ".env" (same folder as docker-compose.yml) and fill every value.
#  NEVER commit the real .env — it is gitignored.
# ==============================================================================

# --- Timezone (controls the 08:00 cron) -------------------------------------
TZ=Africa/Lagos

# --- Windows path to your Markdown vault (Obsidian/Logseq) -------------------
# Use FORWARD slashes. Docker Desktop maps Windows drives transparently.
# Example: C:/Users/Ian/Documents/SecondBrain
VAULT_PATH=C:/Users/CHANGE_ME/Documents/SecondBrain

# --- n8n auth + encryption ---------------------------------------------------
# Generate a strong key:  openssl rand -hex 24   (or any 32+ char random string)
N8N_ENCRYPTION_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Evolution API ----------------------------------------------------------
# Any long random string. You send it as the "apikey" header to the gateway.
EVOLUTION_API_KEY=CHANGE_ME_LONG_RANDOM_APIKEY
# The WhatsApp "instance" name you create at QR-pair time (Section 3).
EVOLUTION_INSTANCE=secondbrain
# Recipient in E.164 WITHOUT the leading '+'. e.g. 2348012345678 (NG), 14155550100 (US)
WA_TARGET_NUMBER=2348012345678

# --- Postgres (Evolution only) ----------------------------------------------
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ==============================================================================
#  The two cloud LLM keys below are NOT read by docker-compose. They are
#  pasted into n8n Credentials (HTTP Header Auth) once, per Section 4.
#  Listed here only so you keep them in one place.
# ==============================================================================
# GEMINI_API_KEY=...        # https://aistudio.google.com/app/apikey  (free tier)
# GROQ_API_KEY=...          # https://console.groq.com/keys          (free tier)
