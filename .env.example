# ==============================================================================
#  Copy to ".env" (same folder as docker-compose.yml) and fill EVERY value.
#  The real .env is gitignored — never commit it.
#    Windows: copy .env.example .env
#    WSL/bash: cp .env.example .env
# ==============================================================================

# --- Timezone (drives the 08:00 cron) ---------------------------------------
TZ=Africa/Lagos

# --- Windows path to your Markdown vault (Obsidian/Logseq) -------------------
# Use FORWARD slashes. Docker Desktop maps Windows drives transparently.
# The drive must be enabled under Docker Desktop > Settings > Resources > File Sharing.
# Example: C:/Users/Ian/Documents/SecondBrain
VAULT_PATH=C:/Users/CHANGE_ME/Documents/SecondBrain

# WRITABLE inbox folder for inbound captures + the action log (docs/07).
# Keep it SEPARATE from the read-only vault. Tip: make it a subfolder of the
# vault (e.g. .../SecondBrain/_inbox) so captures show up in Obsidian too.
INBOX_PATH=C:/Users/CHANGE_ME/Documents/SecondBrain/_inbox

# --- n8n encryption key ------------------------------------------------------
# Encrypts stored credentials. Generate a strong value and DO NOT change it
# later (changing it invalidates saved credentials).
#   bash:       openssl rand -hex 24
#   PowerShell: -join ((48..57)+(97..102) | Get-Random -Count 48 | % {[char]$_})
N8N_ENCRYPTION_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# --- Cloud LLM (pick ONE; both free tiers). Read by n8n via $env -------------
# Groq (default in the workflow): https://console.groq.com/keys
GROQ_API_KEY=CHANGE_ME_GROQ_KEY
# Override the model without touching the workflow. If Groq retires a model,
# just change this. Fast+cheap alternative: llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile
# Google Gemini (optional alternative, see docs/04): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Telegram (the delivery channel; used by every workflow) ----------------
# 1) In Telegram, message @BotFather -> /newbot -> copy the token it gives you.
# 2) Message your new bot once (say "hi"), then get your chat id from:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  -> find "chat":{"id":NNNN}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
